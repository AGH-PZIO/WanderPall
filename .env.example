# Docker Compose database settings
POSTGRES_DB=wanderpall
POSTGRES_USER=wanderpall
POSTGRES_PASSWORD=wanderpall
POSTGRES_PORT=5432

# Docker Compose service ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Backend runtime settings used by Docker Compose
CORS_ORIGINS=http://localhost:5173
JWT_SECRET_KEY=change-me-in-env
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
VERIFICATION_CODE_EXPIRE_MINUTES=15
PASSWORD_RESET_EXPIRE_MINUTES=30

# Frontend runtime settings used by Docker Compose
VITE_API_BASE_URL=http://localhost:8000

# Local migration runner settings
DB_WAIT_ATTEMPTS=30
MIGRATIONS_DIR=infra/db/migrations

# OpenAPI export helper
OPENAPI_OUTPUT_PATH=../docs/openapi.json

# Gmail / travel assistance (backend Module 2)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/travel-assistance/gmail/oauth/callback
GMAIL_TOKEN_ENCRYPTION_KEY=
FRONTEND_OAUTH_REDIRECT_URL=http://localhost:5173/travel-assistance/mail
