  "components": {
    "schemas": {
      "AttachmentInfo": {
        "properties": {
          "attachment_id": {
            "type": "string",
            "title": "Attachment Id"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Filename"
          },
          "mime_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Mime Type"
          },
          "size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Size"
          }
        },
        "type": "object",
        "required": [
          "attachment_id"
        ],
        "title": "AttachmentInfo"
      },
      "AuthorizeUrlResponse": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "AuthorizeUrlResponse"
      },
      "GmailStatusResponse": {
        "properties": {
          "connected": {
            "type": "boolean",
            "title": "Connected"
          },
          "google_email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Google Email"
          },
          "last_sync_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Sync At"
          }
        },
        "type": "object",
        "required": [
          "connected"
        ],
        "title": "GmailStatusResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "SyncResponse": {
        "properties": {
          "scanned": {
            "type": "integer",
            "title": "Scanned",
            "description": "Messages fetched from Gmail in this run"
          },
          "imported": {
            "type": "integer",
            "title": "Imported",
            "description": "New travel-related rows inserted"
          },
          "updated": {
            "type": "integer",
            "title": "Updated",
            "description": "Existing rows updated"
          }
        },
        "type": "object",
        "required": [
          "scanned",
          "imported",
          "updated"
        ],
        "title": "SyncResponse"
      },
      "TestResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "status",
          "message"
        ],
        "title": "TestResponse"
      },
      "TravelDocumentListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/TravelDocumentResponse"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total"
        ],
        "title": "TravelDocumentListResponse"
      },
      "TravelDocumentResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "gmail_message_id": {
            "type": "string",
            "title": "Gmail Message Id"
          },
          "gmail_thread_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Gmail Thread Id"
          },
          "subject": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Subject"
          },
          "snippet": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Snippet"
          },
          "from_addr": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "From Addr"
          },
          "received_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Received At"
          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "confidence": {
            "type": "string",
            "title": "Confidence"
          },
          "is_travel_related": {
            "type": "boolean",
            "title": "Is Travel Related"
          },
          "synced_at": {
            "type": "string",
            "format": "date-time",
            "title": "Synced At"
          },
          "attachments": {
            "items": {
              "$ref": "#/components/schemas/AttachmentInfo"
            },
            "type": "array",
            "title": "Attachments"
          }
        },
        "type": "object",
        "required": [
          "id",
          "gmail_message_id",
          "gmail_thread_id",
          "subject",
          "snippet",
          "from_addr",
          "received_at",
          "category",
          "confidence",
          "is_travel_related",
          "synced_at"
        ],
        "title": "TravelDocumentResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
